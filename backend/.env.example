# ── Banco de dados ──────────────────────────────────────
# Dentro do Docker: DB_HOST = nome do service (postgres)
# Fora do Docker (dev local): DB_HOST = localhost
DB_HOST=postgres
DB_PORT=5432
DB_USER=agendaumento
DB_PASSWORD=TROQUE_AQUI
DB_NAME=agendaumento_db

# ── JWT ─────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
JWT_SECRET=TROQUE_POR_CHAVE_LONGA_E_ALEATORIA
JWT_EXPIRES_IN=7d

# ── API ─────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── CORS ────────────────────────────────────────────────
# Frontend e backend ficam no mesmo dominio:
#   https://agendaumento.couriersknowledge.com       → frontend (Nginx)
#   https://agendaumento.couriersknowledge.com/api   → backend (proxy Nginx → :3000)
FRONTEND_URL=https://agendaumento.couriersknowledge.com

# ── Admins iniciais (seed) ───────────────────────────────
# Troque as senhas logo após o primeiro deploy
ADMIN1_EMAIL=admin1@clinica.com
ADMIN1_SENHA=Admin@123
ADMIN2_EMAIL=admin2@clinica.com
ADMIN2_SENHA=Admin@123
ADMIN3_EMAIL=admin3@clinica.com
ADMIN3_SENHA=Admin@123
