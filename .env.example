# ============================================
# AGENDAUMENTO - Variaveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# ============================================
# BANCO DE DADOS
# ============================================
DB_USER=agendaumento
DB_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE
DB_NAME=agendaumento_db

# ============================================
# JWT (Autenticacao)
# ============================================
# Gere uma chave segura com: openssl rand -base64 32
JWT_SECRET=TROQUE_POR_UMA_CHAVE_SECRETA_LONGA
JWT_EXPIRES_IN=7d

# ============================================
# API
# ============================================
NODE_ENV=production
PORT=3000

# ============================================
# FRONTEND (CORS)
# Frontend e backend ficam no mesmo dominio via Nginx
# Nginx serve / → frontend, /api → backend:3000
# ============================================
FRONTEND_URL=https://agendaumento.couriersknowledge.com

# ============================================
# ADMINS (seed inicial - troque as senhas apos o deploy)
# ============================================
ADMIN1_EMAIL=admin1@clinica.com
ADMIN1_SENHA=Admin@123
ADMIN2_EMAIL=admin2@clinica.com
ADMIN2_SENHA=Admin@123
ADMIN3_EMAIL=admin3@clinica.com
ADMIN3_SENHA=Admin@123

# ============================================
# WHATSAPP (Evolution API - configuravel pelo painel)
# Estes valores sao o fallback; o admin pode sobrescrever
# via /api/admin/configuracoes
# ============================================
# WHATSAPP_API_URL=http://localhost:8080
# WHATSAPP_API_KEY=sua_api_key
# WHATSAPP_INSTANCE_NAME=agendaumento
